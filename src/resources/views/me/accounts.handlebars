<h3 ><span class="material-icons-two-tone md-36">account_box</span>Quản lý sản phẩm</h3><div style='margin-left: 980px'><button type="button" class="btn btn-success btn-sm" onclick="window.location.href='/users/signup'" style='position: right'><span class="material-icons-two-tone">person_add</span>Tạo tài khoản</button></div>
<div class="table-wrapper-scroll-y my-custom-scrollbar">
    
    <table class="table table-bordered table-striped mb-0">
        <thead>
            <tr>
                <th scope="col">#</th>
                <th scope="col">Tên tài khoản</th>
                <th scope="col">Email</th>
                <th scope="col">Số điện thoại</th>
                <th scope="col" colspan='2'>Phân quyền</th>
            </tr>
        </thead>
        <tbody>
            {{#each users}}
            <tr>
                <th scope="row">{{sum @index 1}}</th>
                <td scope="row">{{this.fullName}}</td>
                <td scope="row" >{{this.email}}</td>
                <td scope="row" >{{this.phoneNumber}}</td>
                <td scope="row">{{this.role}}</td>
                <td>
                    <button type="button" class="btn btn-warning btn-sm" onclick="window.location.href='/users/user/{{this._id}}'"><span class="material-icons-two-tone">manage_accounts</span>Chỉnh sửa</button>
                    <a data-toggle="modal" data-id='{{this._id}}' data-target="#delete-item" style='cursor:pointer'><span class="material-icons-two-tone">backspace</span></a>
                    
                </td>

            </tr>
            {{/each}}
            
        </tbody>
    </table>
</div>


<!-- Modal -->
<div class="modal fade" id="delete-item" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="exampleModalLabel">Xóa sản phẩm</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        Bạn chắc chắn muốn xóa sản phẩm này?
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Quay lại</button>
        <button type="button" id='btn-delete' class="btn btn-danger">Xóa</button>
      </div>
    </div>
  </div>
</div>

<form name='delete-form-item' method='POST'></form>

<script>
    document.addEventListener('DOMContentLoaded', function (){

        var itemId;
        var deleteForm = document.forms['delete-form-item'];
        var btnDelete = document.getElementById('btn-delete')
        $('#delete-item').on('show.bs.modal', function (event) {
        var button = $(event.relatedTarget) 
        itemId = button.data('id')
        console.log(itemId)
       
        })
        btnDelete.onclick = function () {
            deleteForm.action = "/me/accounts/" + itemId + "?_method=DELETE";
            deleteForm.submit()
        }
        
    })
</script>